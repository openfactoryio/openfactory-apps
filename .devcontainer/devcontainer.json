{
  "name": "OpenFactory-Apps - Collection of OpenFactory Apps",
  "image": "ghcr.io/openfactoryio/devcontainer-py3.14:v0.6.0",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:4.0.0": {},
    "ghcr.io/openfactoryio/openfactory-sdk/infra:0.6.2": {},
    "ghcr.io/openfactoryio/openfactory-sdk/connectors:0.6.2": {},
    "ghcr.io/openfactoryio/openfactory-sdk/nfs-server:0.6.2": {
      "nfs-mountpoint": "/ofa/nfsvolume",
      "nfs-uid": "1200",
      "nfs-gid": "1200"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "forwardPorts": [
    80
  ],
  "portsAttributes": {
    "80": {
      "label": "Traefik",
      "onAutoForward": "openBrowser"
    }
  },
  "containerEnv": {
    "OPENFACTORY_UNS_SCHEMA": "/workspaces/openfactory-apps/.devcontainer/uns.yml"
  },
  "postCreateCommand": ".devcontainer/postStartScript.sh"
}
